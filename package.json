{
  "name": "fizzy-popper",
  "version": "0.1.0",
  "description": "AI agents for your Fizzy boards",
  "type": "module",
  "bin": {
    "fizzy-popper": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/cli.ts",
    "start": "node dist/cli.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "fizzy",
    "ai",
    "agents",
    "kanban"
  ],
  "license": "MIT",
  "engines": {
