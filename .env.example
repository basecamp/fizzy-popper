# Fizzy API
FIZZY_API_TOKEN=fz_your_token_here
FIZZY_ACCOUNT_SLUG=your_account_slug

# Agent backends (provide at least one)
ANTHROPIC_API_KEY=sk-ant-your-key-here
OPENAI_API_KEY=sk-your-key-here

# Webhook (optional — only needed if using webhook mode)
FIZZY_WEBHOOK_SECRET=your_webhook_signing_secret
FIZZY_WEBHOOK_PORT=4567
